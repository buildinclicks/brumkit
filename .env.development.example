# ============================================================
# .env.development.example
# ============================================================
# Template for local development.
#
# This file is the single source of truth for dev config.
# Copy it to THREE locations before starting:
#
#   cp .env.development.example .env.development          # Docker Compose infra
#   cp .env.development.example packages/database/.env    # Prisma CLI
#   cp .env.development.example apps/web/.env.local       # Next.js app runtime
#
# Next.js ONLY reads env files from apps/web/ — the root file is used
# exclusively by Docker Compose for infrastructure variable substitution.

# ─── APPLICATION ───────────────────────────────────────────
NODE_ENV="development"
NEXT_PUBLIC_APP_URL="http://localhost:4000"
NEXT_PUBLIC_API_URL="http://localhost:4000/api"

# ─── DATABASE (PostgreSQL) ─────────────────────────────────
# App Connection (port 5433 — Docker maps host:5433 → container:5432)
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/broom_kit"

# Docker Postgres Config
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=broom_kit
POSTGRES_PORT=5433

# ─── AUTH.JS ───────────────────────────────────────────────
NEXTAUTH_URL="http://localhost:4000"
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="replace-me-with-openssl-rand-base64-32"

# ─── REDIS (Caching/Rate Limiting) ──────────────────────────
# App Connection (include password matching Docker Redis config below)
REDIS_URL="redis://:redis_secret@localhost:6379"

# Docker Redis Config
REDIS_PASSWORD=redis_secret
REDIS_PORT=6379

# ─── EMAIL ─────────────────────────────────────────────────
# In development (NODE_ENV=development) Mailhog is used automatically.
# In production (NODE_ENV=production) Resend is required (RESEND_API_KEY).
# Note: USE_MAILHOG is not read by the application; email mode is determined
# solely by NODE_ENV.

# App email sender address
FROM_EMAIL="noreply@brumkit.local"

# Mailhog connection settings (used when NODE_ENV=development)
MAILHOG_HOST="localhost"
MAILHOG_PORT="1025"

# Docker Mailhog Config
MAILHOG_SMTP_PORT=1025
MAILHOG_UI_PORT=8025

# Resend API key — leave empty in dev; required when NODE_ENV=production
RESEND_API_KEY=""

# ─── OTHER ─────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
CRON_SECRET="replace-me-with-openssl-rand-base64-32"
ADMIN_EMAIL="admin@brumkit.local"
