{
  "name": "@repo/auth",
  "version": "1.0.0",
  "private": true,
  "description": "Authentication and authorization package with Auth.js v5 and CASL for Brumkit",
  "main": "./src/index.ts",
  "type": "module",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./edge": "./src/edge.ts"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:coverage": "vitest run --coverage",
    "type-check": "tsc --noEmit",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.2",
    "@casl/ability": "^7.0.0",
    "@casl/react": "^7.0.0",
    "@repo/database": "workspace:*",
    "@repo/validation": "workspace:*",
    "bcryptjs": "^3.0.3",
    "next-auth": "^5.0.0-beta.25",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@repo/config-eslint": "workspace:*",
    "@repo/config-typescript": "workspace:*",
    "@repo/config-vitest": "workspace:*",
    "@types/node": "catalog:",
    "eslint": "catalog:",
    "next": "^16.2.9",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "peerDependencies": {
    "@prisma/client": "^7.0.0",
    "next": "^16.0.0",
    "react": "^18.0.0 || ^19.0.0"
  }
