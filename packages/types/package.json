{
  "name": "@repo/types",
  "version": "0.1.0",
  "private": true,
  "description": "Shared TypeScript types for Brumkit monorepo",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./common": "./src/common.ts",
    "./api": "./src/api.ts",
    "./auth": "./src/auth.ts",
    "./utils": "./src/utils.ts"
  },
  "scripts": {
    "type-check": "tsc --noEmit",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "test": "vitest run",
    "test:watch": "vitest watch"
  },
  "devDependencies": {
    "@repo/config-typescript": "workspace:*",
    "@repo/config-vitest": "workspace:*",
    "@types/node": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "keywords": [
    "typescript",
    "types",
    "shared"
  ]
}
