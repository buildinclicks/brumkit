    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "zod": "catalog:"
  },
  "devDependencies": {
    "@prisma/client": "^6.19.2",
    "@repo/config-typescript": "workspace:*",
    "@repo/config-vitest": "workspace:*",
    "@repo/types": "workspace:*",
    "@types/node": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
