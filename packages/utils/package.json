{
  "name": "@repo/utils",
  "version": "2.0.0",
  "private": true,
  "description": "Shared utility functions for Brumkit monorepo",
  "main": "./src/index.ts",
  "type": "module",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./string": "./src/string.ts",
    "./array": "./src/array.ts",
    "./object": "./src/object.ts",
    "./date": "./src/date.ts"
  },
  "scripts": {
    "type-check": "tsc --noEmit",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@repo/types": "workspace:*",
    "lodash-es": "^4.18.1"
  },
  "devDependencies": {
    "@repo/config-typescript": "workspace:*",
    "@repo/config-vitest": "workspace:*",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "keywords": [
    "utilities",
    "helpers",
    "shared"
  ]
}
