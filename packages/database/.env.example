# packages/database/.env
# This file is read by the Prisma CLI (prisma.config.ts via dotenv/config)
# when running migrate, seed, or studio from the packages/database directory.
#
# Copy the root template:
#   cp ../../.env.development.example packages/database/.env
#
# Minimum required for the Prisma CLI:
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/broom_kit

# Required for running integration tests locally.
# In CI this is set inline in .github/workflows/ci.yml.
TEST_DATABASE_URL=postgresql://postgres:postgres@localhost:5433/broom_kit_test
