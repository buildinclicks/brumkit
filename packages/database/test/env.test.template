# Test Database Configuration
# Copy this to packages/database/.env and fill in your values.
# Canonical project name is "broom_kit"; port 5433 is used in Docker dev.

# Test database URL (separate from dev DB to avoid data corruption)
TEST_DATABASE_URL=postgresql://postgres:postgres@localhost:5433/broom_kit_test

# Debug Prisma queries during tests (optional)
DEBUG_TESTS=false

# To set up the test database locally:
# 1. Ensure Docker infra is running:
#    docker compose --env-file .env.development up -d
#
# 2. Create / migrate the test DB:
#    TEST_DATABASE_URL=$TEST_DATABASE_URL pnpm --filter @repo/database db:push
#
# 3. Run tests:
#    pnpm test
