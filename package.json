{
  "name": "brumkit",
  "version": "0.1.0",
  "private": true,
  "description": "Production-ready Next.js 15 starter kit with authentication, authorization, and essential features",
  "repository": {
    "type": "git",
    "url": "https://github.com/buildinclicks/brumkit.git"
  },
  "bugs": {
    "url": "https://github.com/buildinclicks/brumkit/issues"
  },
  "homepage": "https://github.com/buildinclicks/brumkit#readme",
  "author": "BuildInClicks",
  "license": "MIT",
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "dev:web": "turbo dev --filter=web",
    "build:web": "turbo build --filter=web",
    "lint": "turbo lint",
    "type-check": "turbo type-check",
    "test": "turbo test",
    "test:coverage": "turbo test:coverage",
    "test:watch": "turbo test:watch",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,md,json}\"",
    "clean": "turbo clean && rm -rf node_modules",
    "prepare": "husky"
  },
  "lint-staged": {
    "apps/web/**/*.{js,jsx,ts,tsx}": [
      "pnpm --filter web lint:fix",
      "prettier --write"
    ],
    "packages/ui/**/*.{js,jsx,ts,tsx}": [
      "pnpm --filter @repo/ui lint:fix",
      "prettier --write"
    ],
    "packages/auth/**/*.{js,jsx,ts,tsx}": [
      "pnpm --filter @repo/auth lint:fix",
      "prettier --write"
    ],
    "packages/database/**/*.{js,jsx,ts,tsx}": [
      "pnpm --filter @repo/database lint:fix",
      "prettier --write"
    ],
    "packages/email/**/*.{js,jsx,ts,tsx}": [
      "pnpm --filter @repo/email lint:fix",
      "prettier --write"
    ],
    "packages/rate-limit/**/*.{js,jsx,ts,tsx}": [
      "pnpm --filter @repo/rate-limit lint:fix",
      "prettier --write"
    ],
    "packages/types/**/*.{js,jsx,ts,tsx}": [
      "pnpm --filter @repo/types lint:fix",
      "prettier --write"
    ],
    "packages/utils/**/*.{js,jsx,ts,tsx}": [
      "pnpm --filter @repo/utils lint:fix",
      "prettier --write"
    ],
    "packages/validation/**/*.{js,jsx,ts,tsx}": [
      "pnpm --filter @repo/validation lint:fix",
      "prettier --write"
    ],
    "**/*.{json,md,yml,yaml,css}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@testing-library/user-event": "^14.6.1",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitest/coverage-v8": "catalog:",
    "@vitest/ui": "catalog:",
    "eslint": "catalog:",
    "happy-dom": "^20.10.1",
    "husky": "^9.1.7",
    "ioredis": "catalog:",
    "jsdom": "^27.4.0",
    "lint-staged": "^16.2.7",
    "nodemailer": "^8.0.5",
    "prettier": "^3.2.4",
    "turbo": "^2.9.16",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "packageManager": "pnpm@10.0.0",
  "engines": {
    "node": ">=20.19.0",
    "pnpm": ">=10.0.0"
  },
  "pnpm": {
    "overrides": {
      "prismjs@<1.30.0": ">=1.30.0",
      "lodash-es@>=4.0.0 <=4.17.22": ">=4.17.23",
      "next@>=10.0.0 <15.5.18": ">=15.5.18",
      "next@>=15.5.1-canary.0 <15.5.18": ">=15.5.18",
      "fast-xml-parser@>=5.0.9 <=5.3.3": ">=5.3.4",
      "minimatch@<3.1.4": "3.1.4",
      "minimatch@>=9.0.0 <9.0.7": "9.0.7",
      "rollup@>=4.0.0 <4.59.0": ">=4.59.0",
      "flatted@<3.4.2": ">=3.4.2",
      "picomatch@<2.3.2": ">=2.3.2",
      "picomatch@>=4.0.0 <4.0.4": ">=4.0.4",
      "defu@<=6.1.4": ">=6.1.5",
      "effect@<3.20.0": ">=3.20.0"
    }
  }
}
