# ============================================================
# .env.production.example
# ============================================================
# Template for production. Copy to .env.production and supply real values.
# NEVER commit .env.production to version control.
#
# When deploying to Vercel:
#   Set these variables in the Vercel dashboard (Settings → Environment Variables).
#   NEXT_PUBLIC_* must be set before the build step.
#
# When deploying with Docker:
#   docker compose -f docker-compose.full.yml --env-file .env.production up -d

# ─── DATABASE ────────────────────────────────────────────────
# Production connection string — Neon, Supabase, RDS, or self-hosted Postgres.
DATABASE_URL="postgresql://user:secure_password@db.example.com:5432/broom_kit_prod?sslmode=require"

# ─── AUTH.JS ─────────────────────────────────────────────────
# Must match the public URL of your deployed app.
NEXTAUTH_URL="https://brumkit.com"
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-production-secret-key-replace-me"

# ─── APPLICATION ─────────────────────────────────────────────
# Public-facing base URL baked into the client bundle at build time.
NEXT_PUBLIC_APP_URL="https://brumkit.com"
NEXT_PUBLIC_API_URL="https://brumkit.com/api"

# ─── REDIS (Production rate limiting / caching) ───────────────
# Upstash Redis REST credentials (recommended for serverless/Vercel).
UPSTASH_REDIS_REST_URL="https://your-database-id.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your_upstash_redis_token"
# Optional raw connection fallback (used by self-hosted Redis or Docker stack).
REDIS_URL="rediss://default:password@your-database-id.upstash.io:32483"

# ─── EMAIL (Resend) ───────────────────────────────────────────
# Production email is always sent via Resend (NODE_ENV=production).
# Mailhog is only used in development.
RESEND_API_KEY="re_123456789_xxxxxxxxxxxxxxxxxxxx"
FROM_EMAIL="noreply@brumkit.com"
ADMIN_EMAIL="admin@brumkit.com"

# ─── CRON JOBS ───────────────────────────────────────────────
# Required — the cron endpoint rejects requests without this secret.
# Generate with: openssl rand -base64 32
CRON_SECRET="your-production-cron-secret"

# ─── ENVIRONMENT ─────────────────────────────────────────────
NODE_ENV="production"
