{
  "name": "web",
  "version": "1.0.0",
  "private": true,
  "description": "BrumKit web application - Next.js 15 with authentication and authorization",
  "author": "BuildInClicks",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "next dev --port 4000",
    "build": "pnpm --filter @repo/database db:generate && next build",
    "build:docker": "pnpm --filter @repo/database db:generate && next build",
    "start": "next start",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:integration": "vitest run app/actions/account-deletion.test.ts app/actions/email-change.test.ts app/actions/notification.test.ts app/actions/auth.test.ts --reporter=verbose",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@hookform/resolvers": "catalog:",
    "@prisma/client": "^7.8.0",
    "@repo/auth": "workspace:*",
    "@repo/database": "workspace:*",
    "@repo/email": "workspace:*",
    "@repo/rate-limit": "workspace:*",
    "@repo/types": "workspace:*",
    "@repo/ui": "workspace:*",
    "@repo/utils": "workspace:*",
    "@repo/validation": "workspace:*",
    "@tanstack/react-query": "^5.101.0",
    "@tanstack/react-query-devtools": "^5.101.0",
    "lucide-react": "^1.18.0",
    "next": "^16.2.9",
    "next-auth": "^5.0.0-beta.31",
    "next-intl": "^4.13.0",
    "next-themes": "^0.4.6",
    "react": "catalog:",
    "react-dom": "catalog:",
    "react-hook-form": "catalog:",
    "sonner": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@repo/config-eslint": "workspace:*",
    "@repo/config-tailwind": "workspace:*",
    "@repo/config-typescript": "workspace:*",
    "@repo/config-vitest": "workspace:*",
    "@tailwindcss/postcss": "^4.3.0",
    "@tailwindcss/typography": "^0.5.19",
    "@testing-library/react": "^16.3.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.23",
    "eslint": "catalog:",
    "jsdom": "^27.4.0",
    "msw": "^2.12.7",
    "postcss": "^8.5.6",
    "prisma": "^6.19.2",
    "tailwindcss": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:"
  }
}
